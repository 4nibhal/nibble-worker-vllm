{
  "tests": [
    {
      "name": "basic_inference_test",
      "input": {
        "prompt": "Write a short poem about artificial intelligence.",
        "sampling_params": {
          "max_tokens": 64,
          "temperature": 0.1
        }
      },
      "timeout": 120000
    },
    {
      "name": "openai_messages_test",
      "input": {
        "openai_route": "/v1/chat/completions",
        "openai_input": {
          "messages": [
            {
              "role": "system",
              "content": "You are a helpful assistant that writes concise responses."
            },
            {
              "role": "user",
              "content": "Explain what a neural network is in one sentence."
            }
          ],
          "max_tokens": 200,
          "temperature": 0.1
        }
      },
      "timeout": 120000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "MODEL_NAME",
        "value": "HuggingFaceTB/SmolLM2-135M-Instruct"
      },
      {
        "key": "HEALTH_CHECK_INIT_FAST_MODE",
        "value": "false"
      },
      {
        "key": "HEALTH_CHECK_INTERVAL_SECONDS",
        "value": "30"
      },
      {
        "key": "SCALING_MIN_QUEUE_TIME_MS",
        "value": "0"
      },
      {
        "key": "SCALING_THRESHOLD_BUFFER_MS",
        "value": "0"
      },
      {
        "key": "OTEL_EXPORTER_OTLP_ENDPOINT",
        "value": ""
      },
      {
        "key": "POSTHOG_API_KEY",
        "value": ""
      },
      {
        "key": "RUNPOD_GQL_API_URL",
        "value": "https://api.runpod.io/graphql"
      },
      {
        "key": "GIN_MODE",
        "value": "release"
      }
    ],
    "allowedCudaVersions": ["12.9", "12.8", "12.7", "12.6", "12.5"]
  }
}
